type Status = "idle"|"loading"|"playing"|"error";
type View = "guide"|"player";
type LoadState = "idle"|"fetching"|"done"|"error";
type PlayMethod = "proxy"|"direct"|"backup-proxy"|"backup-direct";

// Component to render channel logo with flag fallback on error
function ChannelLogo({ channel, size = 32 }: { channel: Channel | null; size?: number }) {
  const [err, setErr] = useState(false);
  const [prevId, setPrevId] = useState<string | null>(null);

  useEffect(() => {
    if (channel?.id !== prevId) {
      setErr(false);
      setPrevId(channel?.id || null);
    }
  }, [channel, prevId]);

  if (!channel) return null;

  if (err || !channel.logo) {
    return (
      <span style={{ fontSize: size * 0.75, display: "inline-block", lineHeight: 1 }}>
        {channel.flag}
      </span>
    );
  }

  return (
    <img
      src={channel.logo}
      alt={channel.name}
      style={{
        width: size,
        height: size,
        objectFit: "contain",
        borderRadius: 8,
        background: "rgba(255, 255, 255, 0.08)",
        padding: 2,
        display: "inline-block",
        verticalAlign: "middle"
      }}
      onError={() => setErr(true)}
    />
  );
}

export default function Home() {
  const vRef    = useRef<HTMLVideoElement>(null);
  const hlsRef  = useRef<any>(null);
  const gridRef = useRef<HTMLDivElement>(null);

  const [cur,      setCur]      = useState<Channel|null>(null);
  const [status,   setStatus]   = useState<Status>("idle");
  const [errMsg,   setErrMsg]   = useState("");
  const [tab,      setTab]      = useState("channels");
  const [channelSubTab, setChannelSubTab] = useState("all"); // "all", "favorites", "asia", "europe", etc.
  const [search,   setSearch]   = useState("");
  const [view,     setView]     = useState<View>("guide");
  const [showSearch,setShowSearch]=useState(false);
  const [playMethod,setPlayMethod]=useState<PlayMethod|"">("proxy");
  const autoRetryRef = useRef<ReturnType<typeof setTimeout>|null>(null);
  const curRef = useRef<Channel|null>(null);

  // User auth states
  const [user, setUser] = useState<FirebaseUser | null>(null);
  const [authInitialized, setAuthInitialized] = useState(false);
  const [authModalOpen, setAuthModalOpen] = useState(false);
  const [authMode, setAuthMode] = useState<"login" | "signup">("login");
  const [emailInput, setEmailInput] = useState("");
  const [passwordInput, setPasswordInput] = useState("");
  const [authError, setAuthError] = useState("");
  const [authLoading, setAuthLoading] = useState(false);
  const [userDropdownOpen, setUserDropdownOpen] = useState(false);

  // Synced User Data states
  const [favoriteChannels, setFavoriteChannels] = useState<string[]>([]);
  const [watchHistory, setWatchHistory] = useState<string[]>([]);

  // -------------------------------------------------------------
  // Sports Match Center States
  // -------------------------------------------------------------
  const [fancodeMatches, setFancodeMatches] = useState<any[]>([]);
  const [fancodeLoading, setFancodeLoading] = useState(false);

  const [footballMatches, setFootballMatches] = useState<any[]>([]);
  const [footballLoading, setFootballLoading] = useState(false);
  const [footballLeague, setFootballLeague] = useState("PL");
  const [standings, setStandings] = useState<any[]>([]);
  const [standingsLoading, setStandingsLoading] = useState(false);
  const [scorers, setScorers] = useState<any[]>([]);
  const [scorersLoading, setScorersLoading] = useState(false);
  const [scoresFilter, setScoresFilter] = useState("all"); // "all", "live", "finished", "upcoming"
  const [footballRefreshTimer, setFootballRefreshTimer] = useState(60);

  const [showSportzfyEmbed, setShowSportzfyEmbed] = useState(false);

  // Set explicit persistence once on mount and listen to auth changes

  useEffect(() => {
    setPersistence(auth, browserLocalPersistence)
      .then(() => {
        const unsubscribe = onAuthStateChanged(auth, async (firebaseUser) => {
          setUser(firebaseUser);
          if (firebaseUser) {
            const tvData = await getTvUserData(firebaseUser.uid);
            if (tvData) {
              setFavoriteChannels(tvData.favoriteChannels || []);
              setWatchHistory(tvData.watchHistory || []);
            }
          } else {
            const localFavs = localStorage.getItem("tv_favorites");
            if (localFavs) setFavoriteChannels(JSON.parse(localFavs));
            const localHist = localStorage.getItem("tv_history");
            if (localHist) setWatchHistory(JSON.parse(localHist));
          }
          setAuthInitialized(true);
        });
        return () => unsubscribe();
      })
      .catch((err) => {
        console.error("Error setting persistence", err);
        setAuthInitialized(true);
      });
  }, []);

  // Save Favorite status
  const toggleFavorite = useCallback(async (channelId: string) => {
    let newFavs: string[];
    if (favoriteChannels.includes(channelId)) {
      newFavs = favoriteChannels.filter(id => id !== channelId);
    } else {
      newFavs = [...favoriteChannels, channelId];
    }
    setFavoriteChannels(newFavs);

    if (user) {
      await saveTvUserData(user.uid, { favoriteChannels: newFavs });
    } else {
      localStorage.setItem("tv_favorites", JSON.stringify(newFavs));
    }
  }, [user, favoriteChannels]);

  // Save History status
  const addToHistory = useCallback(async (channelId: string) => {
    const filtered = watchHistory.filter(id => id !== channelId);
    const newHist = [channelId, ...filtered].slice(0, 10);
    setWatchHistory(newHist);

    if (user) {
      await saveTvUserData(user.uid, { watchHistory: newHist });
    } else {
      localStorage.setItem("tv_history", JSON.stringify(newHist));
    }
  }, [user, watchHistory]);

  const handleLogout = useCallback(async () => {
    if (confirm("Are you sure you want to log out?")) {
      setUserDropdownOpen(false);
      try {
        await signOut(auth);
        setFavoriteChannels([]);
        setWatchHistory([]);
        localStorage.removeItem("tv_favorites");
        localStorage.removeItem("tv_history");
      } catch (error) {
        console.error("Error signing out:", error);
      }
    }
  }, []);

  const handleAuthSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setAuthError("");
    setAuthLoading(true);
    try {
      if (authMode === "login") {
        await signInWithEmailAndPassword(auth, emailInput, passwordInput);
      } else {
        await createUserWithEmailAndPassword(auth, emailInput, passwordInput);
      }
      setAuthModalOpen(false);
      setEmailInput("");
      setPasswordInput("");
    } catch (err: any) {
      console.error("Auth error:", err);
      let msg = err.message || "An authentication error occurred.";
      if (err.code === "auth/invalid-credential") {
        msg = "Invalid email or password. Please try again.";
      } else if (err.code === "auth/email-already-in-use") {
        msg = "This email is already registered. Try logging in instead.";
      } else if (err.code === "auth/weak-password") {
        msg = "Password must be at least 6 characters long.";
      }
      setAuthError(msg);
    } finally {
      setAuthLoading(false);
    }
  };

  const handleGoogleSignIn = async () => {
    setAuthError("");
    setAuthLoading(true);
    const provider = new GoogleAuthProvider();
    try {
      await signInWithPopup(auth, provider);
      setAuthModalOpen(false);
    } catch (err: any) {
      console.error("Google login error:", err);
      let msg = err.message || "Could not sign in with Google.";
      if (err.code === "auth/unauthorized-domain") {
        msg = "This domain is not authorized for Google Sign-in. Please add it to your Firebase Console settings.";
      }
      setAuthError(msg);
    } finally {
      setAuthLoading(false);
    }
  };

  // World Cup Match Center Feed
  const [wcData, setWcData] = useState<any>(null);
  const [wcLoading, setWcLoading] = useState(false);
  const [wcError, setWcError] = useState(false);
  const [wcSearch, setWcSearch] = useState("");
  const [refreshTimer, setRefreshTimer] = useState(120);

  const fetchWorldCupData = useCallback(async (refresh = false) => {
    setWcLoading(true);
    setWcError(false);
    try {
      const res = await fetch(`/api/worldcup${refresh ? "?refresh=true" : ""}`);
      if (!res.ok) throw new Error("Failed to fetch");
      const data = await res.json();
      setWcData(data);
    } catch (err) {
      console.error("World Cup fetch error:", err);
      setWcError(true);
    } finally {
      setWcLoading(false);
    }
  }, []);

  // Fetch World Cup data when tab changes to worldcup
  useEffect(() => {
    if (tab === "worldcup" && !wcData) {
      fetchWorldCupData();
    }
  }, [tab, wcData, fetchWorldCupData]);

  // Auto-refresh World Cup data every 120s when tab is worldcup
  useEffect(() => {
    if (tab !== "worldcup") return;
    setRefreshTimer(120);

    const interval = setInterval(() => {
      setRefreshTimer(prev => {
        if (prev <= 1) {
          fetchWorldCupData(true);
          return 120;
        }
        return prev - 1;
      });
    }, 1000);

    return () => clearInterval(interval);
  }, [tab, fetchWorldCupData]);

  const filteredReports = useMemo(() => {
    if (!wcData || !wcData.reports) return [];
    if (!wcSearch) return wcData.reports;
    const s = wcSearch.toLowerCase();
    return wcData.reports.filter((r: any) => 
      r.homeTeam.toLowerCase().includes(s) || 
      r.awayTeam.toLowerCase().includes(s)
    );
  }, [wcData, wcSearch]);

  const filteredSchedule = useMemo(() => {
    if (!wcData || !wcData.schedule) return [];
    if (!wcSearch) return wcData.schedule;
    const s = wcSearch.toLowerCase();
    return wcData.schedule.filter((sch: any) => 
      sch.homeTeam.toLowerCase().includes(s) || 
      sch.awayTeam.toLowerCase().includes(s)
    );
  }, [wcData, wcSearch]);

  // Dynamic channels loaded from /api/channels
  const [dynChannels, setDynChannels] = useState<Channel[]>([]);
  const [loadState,   setLoadState]   = useState<LoadState>("idle");
  const [lastUpdated, setLastUpdated] = useState<string>("");
  const [showServers, setShowServers] = useState(false);

  // Fetch live channels from API on mount
  useEffect(() => {
    setLoadState("fetching");
    fetch("/api/channels")
      .then(r => r.json())
      .then(data => {
        if (data.channels && Array.isArray(data.channels)) {
          setDynChannels(data.channels);
          setLastUpdated(data.updatedAt || new Date().toISOString());
          setLoadState("done");
        }
      })
      .catch(() => setLoadState("error"));
  }, []);

  // Merge static featured + dynamic, deduplicate by URL and ID
  const allChannels = useMemo<Channel[]>(() => {
    const seenUrls = new Set(FEATURED.map(c => c.url));
    const seenIds = new Set(FEATURED.map(c => c.id));
    const extra = dynChannels.filter(c => !seenUrls.has(c.url) && !seenIds.has(c.id));
    return [...FEATURED, ...extra];
  }, [dynChannels]);

  // -------------------------------------------------------------
  // Sports API Loaders
  // -------------------------------------------------------------
  const fetchFanCodeMatches = useCallback(async () => {
    setFancodeLoading(true);
    try {
      const res = await fetch("/api/fancode");
      if (!res.ok) throw new Error("Failed");
      const data = await res.json();
      if (data.success) setFancodeMatches(data.streams || []);
    } catch (e) {
      console.error("Fetch fancode streams failed:", e);
    } finally {
      setFancodeLoading(false);
    }
  }, []);

  const fetchFootballMatches = useCallback(async () => {
    setFootballLoading(true);
    try {
      const res = await fetch("/api/football?type=matches");
      if (!res.ok) throw new Error("Failed");
      const data = await res.json();
      if (data.success) setFootballMatches(data.matches || []);
    } catch (e) {
      console.error("Fetch football matches failed:", e);
    } finally {
      setFootballLoading(false);
    }
  }, []);

  const fetchStandings = useCallback(async (lCode: string) => {
    setStandingsLoading(true);
    try {
      const res = await fetch(`/api/football?type=standings&league=${lCode}`);
      if (!res.ok) throw new Error("Failed");
      const data = await res.json();
      if (data.success) setStandings(data.standings || []);
    } catch (e) {
      console.error("Fetch standings failed:", e);
    } finally {
      setStandingsLoading(false);
    }
  }, []);

  const fetchScorers = useCallback(async (lCode: string) => {
    setScorersLoading(true);
    try {
      const res = await fetch(`/api/football?type=scorers&league=${lCode}`);
      if (!res.ok) throw new Error("Failed");
      const data = await res.json();
      if (data.success) setScorers(data.scorers || []);
    } catch (e) {
      console.error("Fetch scorers failed:", e);
    } finally {
      setScorersLoading(false);
    }
  }, []);

  // Fetch match center data on tab shifts
  useEffect(() => {
    if (tab === "fancode") {
      fetchFanCodeMatches();
    } else if (tab === "scores") {
      fetchFootballMatches();
    } else if (tab === "standings") {
      fetchStandings(footballLeague);
    } else if (tab === "scorers") {
      fetchScorers(footballLeague);
    }
  }, [tab, footballLeague, fetchFanCodeMatches, fetchFootballMatches, fetchStandings, fetchScorers]);

  // Scores auto-update loop
  useEffect(() => {
    if (tab !== "scores") return;
    setFootballRefreshTimer(60);

    const interval = setInterval(() => {
      setFootballRefreshTimer(prev => {
        if (prev <= 1) {
          fetchFootballMatches();
          return 60;
        }
        return prev - 1;
      });
    }, 1000);

    return () => clearInterval(interval);
  }, [tab, fetchFootballMatches]);

  const px = (u: string) => `/api/proxy?url=${encodeURIComponent(u)}`;

  const kill = useCallback(() => {
    if (autoRetryRef.current) { clearTimeout(autoRetryRef.current); autoRetryRef.current = null; }
    if (hlsRef.current) { hlsRef.current.destroy(); hlsRef.current = null; }
    const v = vRef.current;
    if (v) { v.pause(); v.removeAttribute("src"); v.load(); }
  }, []);

  // Core: try ONE specific URL either via proxy or direct
  const tryOneUrl = useCallback(async (raw: string, useProxy: boolean): Promise<boolean> => {
    const src = useProxy ? px(raw) : raw;
    const v = vRef.current; if (!v) return false;
    // Native HLS (Safari/iOS)
    if (v.canPlayType("application/vnd.apple.mpegurl")) {
      if (hlsRef.current) { hlsRef.current.destroy(); hlsRef.current = null; }
      v.src = src;
      try { await v.play(); setStatus("playing"); return true; } catch { return false; }
    }
    const { default: Hls } = await import("hls.js");
    if (!Hls.isSupported()) return false;
    if (hlsRef.current) { hlsRef.current.destroy(); hlsRef.current = null; }
    return new Promise<boolean>(res => {
      const h = new Hls({
        enableWorker: true,
        lowLatencyMode: false,       // false = more stable for live TV
        maxBufferLength: 30,
        maxMaxBufferLength: 60,
        fragLoadingTimeOut: 60000,   // 60s – segments need time especially at low bandwidth
        manifestLoadingTimeOut: 15000,
        levelLoadingTimeOut: 15000,
        fragLoadingMaxRetry: 4,
        manifestLoadingMaxRetry: 3,
        levelLoadingMaxRetry: 3,
        startLevel: 0,               // 0 = start at LOWEST quality for fastest initial load
        autoStartLoad: true,
        debug: false,
      });
      hlsRef.current = h;
      // 30-second timeout per attempt
      const t = setTimeout(() => { h.destroy(); if (hlsRef.current === h) hlsRef.current = null; res(false); }, 30000);
      h.on(Hls.Events.MANIFEST_PARSED, () => {
        clearTimeout(t);
        v.play()
          .then(() => { setStatus("playing"); res(true); })
          .catch(() => { setStatus("playing"); res(true); });
      });
      h.on(Hls.Events.ERROR, (_: any, d: any) => {
        if (d.fatal) { clearTimeout(t); h.destroy(); if (hlsRef.current === h) hlsRef.current = null; res(false); }
      });
      h.loadSource(src);
      h.attachMedia(v);
    });
  }, []);


  // Auto-cascade retry playing
  const playChannel = useCallback(async (ch: Channel) => {
    kill();
    setShowSportzfyEmbed(false);
    setCur(ch);
    curRef.current = ch;
    setStatus("loading");
    setErrMsg("");
    setView("player");
    addToHistory(ch.id);

    // ── Sportzfy Embed: no HLS, just show iframe ─────────────────────────────
    if (ch.url === "SPORTZFY_EMBED") {
      setShowSportzfyEmbed(true);
      setStatus("playing");
      return;
    }
    // ─────────────────────────────────────────────────────────────────────────

    // Method 1: Proxy main URL
    setPlayMethod("proxy");
    let ok = await tryOneUrl(ch.url, true);
    if (ok) return;


    // Method 2: Direct main URL (no proxy)
    setPlayMethod("direct");
    if (curRef.current?.id !== ch.id) return;
    setStatus("loading");
    ok = await tryOneUrl(ch.url, false);
    if (ok) return;

    // Method 3: Proxy backup URL
    if (ch.backup) {
      setPlayMethod("backup-proxy");
      if (curRef.current?.id !== ch.id) return;
      setStatus("loading");
      ok = await tryOneUrl(ch.backup, true);
      if (ok) return;

      // Method 4: Direct backup URL
      setPlayMethod("backup-direct");
      if (curRef.current?.id !== ch.id) return;
      setStatus("loading");
      ok = await tryOneUrl(ch.backup, false);
      if (ok) return;
    }

    // All failed
    if (curRef.current?.id === ch.id) {
      setStatus("error");
      setErrMsg("This channel may be geo-restricted or temporarily offline.");
    }
  }, [kill, tryOneUrl]);

  // Handle play for fancode match object
  const playFancodeMatch = useCallback((m: any) => {
    const virtualChannel: Channel = {
      id: `fancode_${m.match_id}`,
      name: m.match_name,
      flag: m.event_category === "cricket" ? "🏏" : "⚽",
      country: m.event_name,
      region: "sports",
      url: m.stream_link,
      quality: "HD Live",
      logo: m.banner || m.team_1_flag
    };
    playChannel(virtualChannel);
  }, [playChannel]);

  // Auto-play BTV National if requested
  useEffect(() => {
    if (typeof window !== "undefined") {
      const params = new URLSearchParams(window.location.search);
      const watch = params.get("watch");
      const channel = params.get("channel");
      if (watch === "worldcup" || watch === "btv" || channel === "btv") {
        const btvCh = FEATURED.find(c => c.id === "btv");
        if (btvCh) {
          playChannel(btvCh);
        }
      }
    }
  }, [playChannel]);

  // Direct manual retry
  const retryDirect = useCallback(async () => {
    const ch = curRef.current;
    if (!ch) return;
    kill();
    setStatus("loading");
    setErrMsg("");
    setPlayMethod("direct");
    let ok = await tryOneUrl(ch.url, false);
    if (!ok && ch.backup) ok = await tryOneUrl(ch.backup, false);
    if (!ok && curRef.current?.id === ch.id) {
      setStatus("error");
      setErrMsg("Direct stream also failed. Try another channel.");
    }
  }, [kill, tryOneUrl]);

  useEffect(() => () => kill(), [kill]);

  // Browser back button sync
  useEffect(() => {
    const fn = () => {
      if (view === "player") { setView("guide"); kill(); setCur(null); setStatus("idle"); }
    };
    if (view === "player") window.history.pushState({v:"player"}, "");
    window.addEventListener("popstate", fn);
    return () => window.removeEventListener("popstate", fn);
  }, [view, kill]);

  // TV Channel filters
  const filteredChannels = useMemo(() => {
    return allChannels.filter(ch => {
      const bySubTab = channelSubTab === "all" 
        ? true 
        : channelSubTab === "favorites" 
          ? favoriteChannels.includes(ch.id) 
          : channelSubTab === "worldcup"
            ? ch.isWorldCup
            : ch.region === channelSubTab;

      const byS = !search || 
        ch.name.toLowerCase().includes(search.toLowerCase()) || 
        ch.country.toLowerCase().includes(search.toLowerCase());

      return bySubTab && byS;
    });
  }, [allChannels, channelSubTab, search, favoriteChannels]);

  // Group TV channels by country
  const groupedChannels = useMemo(() => {
    const g: Record<string, Channel[]> = {};
    filteredChannels.forEach(ch => { 
      if (!g[ch.country]) g[ch.country] = []; 
      g[ch.country].push(ch); 
    });
    return g;
  }, [filteredChannels]);

  // Football matches filter
  const filteredFootballMatches = useMemo(() => {
    if (scoresFilter === "all") return footballMatches;
    return footballMatches.filter(m => m.status.toLowerCase() === scoresFilter);
  }, [footballMatches, scoresFilter]);

  const timeStr = lastUpdated ? new Date(lastUpdated).toLocaleTimeString([], {hour:"2-digit",minute:"2-digit"}) : "";

  // -------------------------------------------------------------
  // Render sub-components to keep UI clean and modular
  // -------------------------------------------------------------
  const renderVideoPlayer = () => {
    // ── Sportzfy iframe embed mode ─────────────────────────────────────────────
    if (cur?.url === "SPORTZFY_EMBED" || showSportzfyEmbed) {
      return (
        <div style={{display:"flex",flexDirection:"column",width:"100%",height:"100%"}}>
          {/* Topbar */}
          <div style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",flexShrink:0,background:"rgba(12,12,32,0.8)",borderBottom:"1px solid var(--border)",zIndex:10}}>
            <button className="mobile-only-btn" onClick={() => {setView("guide");setCur(null);setShowSportzfyEmbed(false);setStatus("idle");}}
              style={{background:"none",border:"none",color:"var(--accent)",fontSize:26,cursor:"pointer",lineHeight:1,paddingRight:10}}>‹</button>
            <div style={{flex:1,display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:18}}>📺</span>
              <div>
                <div style={{fontWeight:800,fontSize:13,color:"#fff"}}>Sportzfy Live — Bangladesh Channels</div>
                <div style={{fontSize:10,color:"#f59e0b",fontWeight:700}}>🇧🇩 T Sports · GTV · BTV · NTV + more</div>
              </div>
            </div>
            <button onClick={() => {setShowSportzfyEmbed(false);setCur(null);setStatus("idle");}}
              style={{background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.3)",borderRadius:8,padding:"4px 10px",color:"#ef4444",fontSize:11,fontWeight:800,cursor:"pointer"}}>
              ✕ Close
            </button>
          </div>
          {/* Full Sportzfy website embed */}
          <div style={{flex:1,position:"relative",background:"#000"}}>
            <iframe
              src="https://sportzfytvbd.com/"
              style={{width:"100%",height:"100%",border:"none",display:"block"}}
              allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
              allowFullScreen
              title="Sportzfy Live Bangladesh"
            />
            <div style={{position:"absolute",bottom:8,right:8,background:"rgba(0,0,0,0.7)",borderRadius:6,padding:"3px 8px",fontSize:9,color:"#f59e0b",fontWeight:700,pointerEvents:"none"}}>
              📱 sportzfytvbd.com
            </div>
          </div>
        </div>
      );
    }
    // ──────────────────────────────────────────────────────────────────────────────

    return (
      <div style={{display:"flex",flexDirection:"column",width:"100%",height:"100%"}}>
        {/* Topbar */}

        <div style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",flexShrink:0,background:"rgba(12,12,32,0.8)",borderBottom:"1px solid var(--border)",zIndex:10}}>
          {/* Mobile Back Button */}
          <button className="mobile-only-btn" onClick={() => {setView("guide");kill();setCur(null);setStatus("idle");}}
            style={{background:"none",border:"none",color:"var(--accent)",fontSize:26,cursor:"pointer",lineHeight:1,paddingRight:10}}>‹</button>
          
          <div style={{flex:1,minWidth:0,display:"flex",alignItems:"center",gap:8}}>
            <ChannelLogo channel={cur} size={26} />
            <div style={{minWidth:0}}>
              <div style={{fontWeight:800,fontSize:13,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",color:"#fff"}}>{cur?.name}</div>
              <div style={{fontSize:10,color:"var(--neon-green)",fontWeight:700}}>{cur?.country} {cur?.isWorldCup?"🏆 WC":cur?.quality||"Live Stream"}</div>
            </div>
          </div>

          {/* Heart Favorite Button */}
          {cur && (
            <button onClick={() => toggleFavorite(cur.id)}
              style={{
                background: favoriteChannels.includes(cur.id) ? "rgba(239,68,68,.12)" : "var(--surface)",
                border: `1.5px solid ${favoriteChannels.includes(cur.id) ? "rgba(239,68,68,.4)" : "var(--border)"}`,
                borderRadius: 10,
                padding: "5px 10px",
                color: favoriteChannels.includes(cur.id) ? "#ef4444" : "var(--muted)",
                fontSize: 10,
                fontWeight: 800,
                display: "flex",
                alignItems: "center",
                gap: 4
              }}>
              {favoriteChannels.includes(cur.id) ? "❤️" : "🤍"}
            </button>
          )}

          {/* Server Selector toggle */}
          <button onClick={() => setShowServers(!showServers)}
            style={{background:"var(--surface)",border:"1.5px solid var(--border)",borderRadius:10,padding:"5px 10px",color:"var(--text)",fontSize:10,fontWeight:800}}>
            ⚙ Control Panel
          </button>
        </div>

        {/* Server Selection Panel */}
        {showServers && (
          <div className="glass-panel" style={{padding:"10px 14px",borderBottom:"1px solid var(--border)",display:"flex",gap:8,flexWrap:"wrap",animation:"fadeIn .2s ease",zIndex:9}}>
            <span style={{fontSize:10,color:"var(--muted)",fontWeight:800,alignSelf:"center",letterSpacing:0.5}}>SERVERS:</span>
            <button className="srv-btn" onClick={() => cur && playChannel(cur)}>🔄 Auto Retry</button>
            {cur?.backup && <button className="srv-btn" onClick={retryDirect}>⚡ Server 2 (Direct)</button>}
            <button className="srv-btn" onClick={retryDirect}>🔁 Direct Stream</button>
            <div style={{display:"flex",alignItems:"center",gap:6,marginLeft:"auto"}}>
              <div style={{width:6,height:6,borderRadius:"50%",background:status==="playing"?"#10b981":status==="loading"?"var(--gold)":"#ef4444",animation:status==="loading"?"glow-pulse-g 1s infinite":"none"}}/>
              <span style={{fontSize:9,fontWeight:900,color:status==="playing"?"#10b981":status==="loading"?"var(--gold)":"#ef4444"}}>
                {status==="playing"?"PLAYING":status==="loading"?"LOADING":"ERROR"}
              </span>
            </div>
          </div>
        )}

        {/* Video Area */}
        <div style={{position:"relative",background:"#000",width:"100%",aspectRatio:"16/9",flexShrink:0,borderBottom:"1px solid var(--border)"}}>
          {status==="loading" && (
            <div style={{position:"absolute",inset:0,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",background:"rgba(6,6,16,0.92)",zIndex:5}}>
              <div style={{width:36,height:36,border:"3px solid #161630",borderTop:"3px solid var(--neon-green)",borderRadius:"50%",animation:"spin .75s linear infinite",marginBottom:12}}/>
              <div style={{color:"var(--muted)",fontSize:11,fontWeight:600,letterSpacing:0.5}}>ESTABLISHING CRYPTO-CONNECTION…</div>
            </div>
          )}
          {status==="loading" && playMethod && playMethod !== "proxy" && (
            <div style={{position:"absolute",bottom:10,left:"50%",transform:"translateX(-50%)",background:"rgba(16,185,129,0.2)",border:"1px solid var(--neon-green)",borderRadius:20,padding:"4px 14px",fontSize:9,fontWeight:800,color:"#fff",zIndex:6}}>
              {playMethod==="direct" && "⚡ Direct Link (No Proxy)"}
              {playMethod==="backup-proxy" && "🔄 Trying Backup Stream"}
              {playMethod==="backup-direct" && "⚡ Trying Backup Direct Link"}
            </div>
          )}
          {status==="error" && (
            <div style={{position:"absolute",inset:0,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",background:"rgba(6,6,16,0.96)",zIndex:5,padding:24,textAlign:"center"}}>
              <span style={{fontSize:40,marginBottom:12}}>📡</span>
              <div style={{color:"#ef4444",fontWeight:900,fontSize:14,marginBottom:6,letterSpacing:0.5}}>SIGNAL TEMPORARILY LOST</div>
              <div style={{color:"var(--muted)",fontSize:11,marginBottom:18,maxWidth:280,lineHeight:1.4}}>{errMsg}</div>
              <div style={{display:"flex",gap:8,flexWrap:"wrap",justifyContent:"center"}}>
                <button onClick={() => cur && playChannel(cur)} style={{padding:"8px 14px",borderRadius:10,background:"var(--accent)",border:"none",color:"#fff",fontWeight:800,fontSize:11}}>🔄 Retry</button>
                <button onClick={retryDirect} style={{padding:"8px 14px",borderRadius:10,background:"rgba(16,185,129,0.15)",border:"1px solid var(--neon-green)",color:"var(--neon-green)",fontWeight:800,fontSize:11}}>⚡ Direct</button>
                <button onClick={() => setShowSportzfyEmbed(true)} style={{padding:"8px 14px",borderRadius:10,background:"rgba(234,179,8,0.15)",border:"1px solid var(--gold)",color:"var(--gold)",fontWeight:800,fontSize:11}}>📱 Sportzfy Web</button>
              </div>
            </div>
          )}
          {/* Sportzfy iframe fallback — loads sportzfytvbd.com directly in browser */}
          {showSportzfyEmbed && (
            <div style={{position:"absolute",inset:0,zIndex:20,display:"flex",flexDirection:"column"}}>
              <div style={{display:"flex",alignItems:"center",gap:8,padding:"6px 10px",background:"rgba(234,179,8,0.15)",borderBottom:"1px solid var(--gold)"}}>
                <span style={{fontSize:11,fontWeight:900,color:"var(--gold)"}}>📱 SPORTZFY WEB — {cur?.name}</span>
                <button onClick={() => setShowSportzfyEmbed(false)} style={{marginLeft:"auto",background:"none",border:"none",color:"var(--muted)",fontSize:18,cursor:"pointer",lineHeight:1}}>✕</button>
              </div>
              <iframe
                src="https://sportzfytvbd.com/live-match-schedule/"
                style={{flex:1,border:"none",background:"#000"}}
                allow="autoplay; fullscreen; encrypted-media"
                title="Sportzfy Live"
              />
            </div>
          )}
          <video ref={vRef} style={{width:"100%",height:"100%",background:"#000",display:showSportzfyEmbed?"none":"block"}}
            controls playsInline crossOrigin="anonymous"
            onPlay={() => setStatus("playing")}
            onWaiting={() => {if(status==="playing") setStatus("loading");}}
            onPlaying={() => setStatus("playing")}
            onError={() => {
              // Chrome fires this for .m3u8 natively — ignore when HLS.js is active
              if (!hlsRef.current && cur) {
                setStatus("error");
                setErrMsg("Stream unavailable. Try Sportzfy Web for BD sports channels.");
              }
            }}/>
        </div>
      </div>
    );
  };

  return (
    <>
      <style>{`
        .mobile-only-btn { display: none; }
        .desktop-layout { display: grid; grid-template-columns: 1.4fr 1fr; height: 100vh; width: 100vw; background: var(--bg); overflow: hidden; }
        .pane-left { display: flex; flex-direction: column; height: 100vh; border-right: 1px solid var(--border); background: #030308; }
        .pane-right { display: flex; flex-direction: column; height: 100vh; background: var(--bg); }
        .subtab-chip { padding: 5px 12px; border-radius: 20px; border: 1.5px solid var(--border); background: var(--surface); color: var(--muted); font-size: 10px; font-weight: 800; cursor: pointer; white-space: nowrap; transition: all 0.2s ease; }
        .subtab-chip:hover { border-color: var(--accent); color: #fff; }
        .subtab-chip.active { background: var(--accent); border-color: var(--accent); color: #fff; box-shadow: 0 0 10px var(--accent-glow); }
        .subtab-chip.wc-chip.active { background: var(--gold); border-color: var(--gold); color: #fff; box-shadow: 0 0 10px var(--gold-glow); }
        
        .league-chip { display: flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 10px; border: 1.5px solid var(--border); background: var(--surface); color: var(--text); font-size: 11px; font-weight: 800; cursor: pointer; transition: all 0.2s ease; }
        .league-chip.active { border-color: var(--neon-green); background: rgba(16, 185, 129, 0.12); box-shadow: 0 0 10px var(--neon-green-glow); color: var(--neon-green); }

        .sports-ticker-card { padding: 12px; border-radius: 14px; background: var(--surface); border: 1.5px solid var(--border); transition: all 0.2s ease; }
        .sports-ticker-card:hover { border-color: var(--accent); transform: translateY(-2px); }

        .fancode-card { border-radius: 16px; background: linear-gradient(135deg, rgba(12,12,32,0.8), rgba(6,6,16,0.9)); border: 1.5px solid var(--border); overflow: hidden; position: relative; display: flex; flex-direction: column; transition: all 0.25s ease; cursor: pointer; }
        .fancode-card:hover { border-color: var(--neon-green); transform: translateY(-3px); box-shadow: 0 5px 15px rgba(16,185,129,0.1); }
        .fancode-card-badge { position: absolute; top: 10px; left: 10px; background: var(--neon-green); color: #fff; font-size: 8px; font-weight: 900; padding: 3px 8px; border-radius: 4px; letter-spacing: 0.5px; text-transform: uppercase; }

        @media (max-width: 1023px) {
          .mobile-only-btn { display: block; }
          .desktop-layout { display: flex; flex-direction: column; height: 100vh; }
          .pane-left { display: ${view === "player" ? "flex" : "none"}; height: auto; border-right: none; }
          .pane-right { display: ${view === "guide" ? "flex" : "none"}; height: 100vh; }
          .mobile-player-pane { display: ${view === "player" ? "flex" : "none"}; flex: 1; flex-direction: column; overflow: hidden; }
        }
      `}</style>

      <div className="desktop-layout">
        
        {/* ── LEFT PANE: PLAYER / LAUNCHER ───────────────────────────────────── */}
        <div className="pane-left">
          {cur ? (
            renderVideoPlayer()
          ) : (
            <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",flex:1,padding:24,textAlign:"center",background:"radial-gradient(circle at center, #0a0a20 0%, #030308 100%)"}}>
              <div className="glow-pulse-gold" style={{width:70,height:70,borderRadius:"50%",background:"rgba(245,158,11,0.06)",border:"2px solid var(--gold)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:32,marginBottom:20}}>
                📺
              </div>
              <h1 style={{fontSize:20,fontWeight:900,color:"#fff",letterSpacing:0.5,marginBottom:6}}>SOHAN TV LIVE CENTER</h1>
              <p style={{fontSize:12,color:"var(--muted)",maxWidth:300,lineHeight:1.6,marginBottom:24}}>Select an IPTV TV channel, a live sports stream, or track football scores from the dashboard to begin watching.</p>
              
              {/* Featured Channels Quick Row */}
              <div style={{width:"100%",maxWidth:400}}>
                <div style={{fontSize:9,fontWeight:900,color:"var(--gold)",letterSpacing:1,textTransform:"uppercase",marginBottom:10,textAlign:"left"}}>Quick Broadcasters</div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(3, 1fr)",gap:8}}>
                  {FEATURED.slice(0, 3).map(ch => (
                    <button key={ch.id} onClick={() => playChannel(ch)} className="subtab-chip" style={{padding:"8px 6px",textAlign:"center"}}>
                      {ch.flag} {ch.name}
                    </button>
                  ))}
                </div>
              </div>

              {/* Sportzfy Web Quick Launch */}
              <div style={{width:"100%",maxWidth:400,marginTop:16}}>
                <div style={{fontSize:9,fontWeight:900,color:"#f59e0b",letterSpacing:1,textTransform:"uppercase",marginBottom:10,textAlign:"left"}}>📱 Sportzfy BD Sports</div>
                <button
                  onClick={() => {
                    // Create a virtual "sportzfy" channel that renders the iframe
                    const sportzfyCh: Channel = {id:"sportzfy-web",name:"Sportzfy Live BD",flag:"🇧🇩",country:"Bangladesh",region:"sports",url:"SPORTZFY_EMBED",quality:"HD"};
                    setCur(sportzfyCh);
                    setView("player");
                    setShowSportzfyEmbed(true);
                    setStatus("playing");
                  }}
                  style={{
                    width:"100%",padding:"12px 16px",borderRadius:12,
                    background:"linear-gradient(135deg,rgba(245,158,11,0.15),rgba(234,88,12,0.1))",
                    border:"1.5px solid rgba(245,158,11,0.4)",color:"#f59e0b",
                    fontWeight:900,fontSize:12,cursor:"pointer",display:"flex",
                    alignItems:"center",justifyContent:"center",gap:8
                  }}
                >
                  📺 Open Sportzfy Live — BD Channels (T Sports, GTV &amp; more)
                </button>
                <div style={{fontSize:9,color:"var(--muted)",marginTop:6,textAlign:"center"}}>
                  Loads Sportzfy's website directly in your browser. Best for Bangladesh users.
                </div>
              </div>
            </div>
          )}


          {/* On Mobile when playing, render the browse panel right below the video player */}
          {cur && (
            <div className="mobile-player-pane">
              <div style={{flex:1,overflowY:"auto",background:"#030308"}}>
                <div style={{padding:"12px 14px 4px",fontSize:10,fontWeight:900,color:"var(--muted)",textTransform:"uppercase",letterSpacing:0.5}}>
                  Streaming Next ({allChannels.length - 1} channels available)
                </div>
                {allChannels.filter(c => c.id !== cur?.id).map(ch => (
                  <button key={ch.id} onClick={() => playChannel(ch)}
                    style={{width:"100%",border:"none",background:"transparent",textAlign:"left",color:"var(--text)",display:"flex",alignItems:"center",gap:10,padding:"10px 14px",borderBottom:"1px solid var(--border)"}}>
                    <ChannelLogo channel={ch} size={28} />
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{fontSize:13,fontWeight:700,color:"#fff"}}>{ch.name}</div>
                      <div style={{fontSize:10,color:"var(--muted)"}}>{ch.country} {ch.isWorldCup?"🏆":""} {ch.quality||""}</div>
                    </div>
                    <span style={{fontSize:11,color:"var(--accent)"}}>WATCH ▶</span>
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* ── RIGHT PANE: INTERACTIVE DASHBOARD ───────────────────────────────── */}
        <div className="pane-right">
          
          {/* Header */}
          <header style={{flexShrink:0,background:"rgba(12,12,32,0.9)",borderBottom:"1px solid var(--border)",paddingTop:"var(--safe-t)"}}>
            <div style={{display:"flex",alignItems:"center",gap:10,padding:"12px 16px 8px"}}>
              <div style={{flex:1,display:"flex",alignItems:"center",gap:8}}>
                <span style={{fontSize:24}}>⚽</span>
                <div>
                  <div style={{fontWeight:900,fontSize:16,background:"linear-gradient(90deg,#10b981,#7c3aed,#f59e0b)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent"}}>SOHAN SPORTS TV</div>
                  <div style={{display:"flex",alignItems:"center",gap:4,marginTop:2}}>
                    <span style={{fontSize:9,color:"var(--muted)"}}>{allChannels.length} TV Channels</span>
                    <span style={{width:3,height:3,borderRadius:"50%",background:"var(--muted)"}}/>
                    <span style={{fontSize:9,color:"var(--neon-green)",fontWeight:700}}>● LIVE MATCH CENTER</span>
                  </div>
                </div>
              </div>

              {/* Search Toggle */}
              <button onClick={() => setShowSearch(!showSearch)}
                style={{background:"var(--surface)",border:"1px solid var(--border)",fontSize:14,cursor:"pointer",color:showSearch?"var(--accent)":"var(--text)",padding:"6px 10px",borderRadius:10}}>
                🔍
              </button>

              {/* Profile Account Dropdown */}
              <div style={{position: "relative"}}>
                <button onClick={() => { if (user) setUserDropdownOpen(!userDropdownOpen); else setAuthModalOpen(true); }}
                  style={{
                    background: user ? "rgba(124,58,237,.15)" : "var(--surface)",
                    border: `1.5px solid ${user ? "var(--accent)" : "var(--border)"}`,
                    borderRadius: 12,
                    padding: "6px 12px",
                    color: "var(--text)",
                    fontSize: 10,
                    fontWeight: 800,
                    display: "flex",
                    alignItems: "center",
                    gap: 6
                  }}>
                  {user ? "👤 Account" : "🔑 Login"}
                </button>
                {userDropdownOpen && user && (
                  <div className="glass-panel" style={{
                    position: "absolute",
                    top: "100%",
                    right: 0,
                    marginTop: 6,
                    borderRadius: 12,
                    padding: 8,
                    zIndex: 100,
                    minWidth: 160,
                    boxShadow: "0 4px 12px rgba(0,0,0,.5)"
                  }}>
                    <div style={{fontSize:10,color:"var(--muted)",fontWeight:800,padding:"4px 8px",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>
                      {user.email}
                    </div>
                    <div style={{height:1,background:"var(--border)",margin:"4px 0"}}/>
                    <button onClick={handleLogout}
                      style={{
                        width: "100%",
                        background: "none",
                        border: "none",
                        color: "#f87171",
                        textAlign: "left",
                        padding: "6px 8px",
                        fontSize: 11,
                        fontWeight: 800,
                        borderRadius: 6
                      }}>
                      🚪 Log Out
                    </button>
                  </div>
                )}
              </div>
            </div>

            {/* Search Input Bar */}
            {showSearch && (
              <div style={{display:"flex",alignItems:"center",gap:8,background:"var(--surface)",borderTop:"1px solid var(--border)",padding:"8px 16px",animation:"fadeIn .2s ease"}}>
                <span style={{color:"var(--muted)"}}>🔍</span>
                <input autoFocus placeholder="Search matches, channels, countries…" value={search}
                  onChange={e => setSearch(e.target.value)}
                  style={{flex:1,background:"transparent",border:"none",outline:"none",color:"var(--text)",fontSize:13}}/>
                <button onClick={() => {setSearch("");setShowSearch(false);}}
                  style={{background:"none",border:"none",color:"var(--muted)",fontSize:16}}>✕</button>
              </div>
            )}
          </header>

          {/* Sub-Header SubTab Bar (For TV Channels Tab ONLY) */}
          {tab === "channels" && (
            <div style={{flexShrink:0,background:"#080816",padding:"8px 16px",borderBottom:"1px solid var(--border)",display:"flex",gap:6,overflowX:"auto",scrollbarWidth:"none"}}>
              <button className={`subtab-chip${channelSubTab==="all"?" active":""}`} onClick={() => setChannelSubTab("all")}>All Channels</button>
              <button className={`subtab-chip${channelSubTab==="favorites"?" active":""}`} onClick={() => setChannelSubTab("favorites")}>❤️ Favorites</button>
              <button className={`subtab-chip wc-chip${channelSubTab==="worldcup"?" active":""}`} onClick={() => setChannelSubTab("worldcup")}>🏆 World Cup</button>
              <button className={`subtab-chip${channelSubTab==="sports"?" active":""}`} onClick={() => setChannelSubTab("sports")}>⚽ Sports</button>
              <button className={`subtab-chip${channelSubTab==="asia"?" active":""}`} onClick={() => setChannelSubTab("asia")}>Asia</button>
              <button className={`subtab-chip${channelSubTab==="middleeast"?" active":""}`} onClick={() => setChannelSubTab("middleeast")}>Arab</button>
              <button className={`subtab-chip${channelSubTab==="europe"?" active":""}`} onClick={() => setChannelSubTab("europe")}>Europe</button>
              <button className={`subtab-chip${channelSubTab==="americas"?" active":""}`} onClick={() => setChannelSubTab("americas")}>Americas</button>
            </div>
          )}

          {/* Sports Center League Selector Chips (For Scores / Standings / Scorers tabs) */}
          {(tab === "scores" || tab === "standings" || tab === "scorers") && (
            <div style={{flexShrink:0,background:"#080816",padding:"10px 16px",borderBottom:"1px solid var(--border)",display:"flex",gap:6,overflowX:"auto",scrollbarWidth:"none"}}>
              {LEAGUES.map(l => (
                <button key={l.code} className={`league-chip${footballLeague===l.code?" active":""}`}
                  onClick={() => setFootballLeague(l.code)}>
                  {l.name}
                </button>
              ))}
            </div>
          )}

          {/* Main Dashboard Scrollable Content */}
          <div ref={gridRef} style={{flex:1,overflowY:"auto",padding:"16px",background:"#04040a"}}>
            
            {/* ────────────── TAB: TV CHANNELS ────────────── */}
            {tab === "channels" && (
              <div className="fade-in">
                {/* Recently Watched */}
                {watchHistory.length > 0 && channelSubTab === "all" && (
                  <div style={{marginBottom:20}}>
                    <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:10}}>
                      <span style={{fontSize:14}}>⏳</span>
                      <span style={{fontWeight:900,fontSize:10,color:"var(--muted)",textTransform:"uppercase",letterSpacing:1}}>Recently Watched</span>
                    </div>
                    <div style={{display:"flex",gap:8,overflowX:"auto",paddingBottom:6,scrollbarWidth:"none"}}>
                      {watchHistory.map(id => {
                        const ch = allChannels.find(c => c.id === id);
                        if (!ch) return null;
                        return (
                          <button key={ch.id} onClick={() => playChannel(ch)}
                            style={{
                              display:"flex",
                              flexDirection:"column",
                              alignItems:"center",
                              justifyContent:"center",
                              gap:6,
                              padding:"10px 8px",
                              borderRadius:14,
                              border:`1.5px solid ${cur?.id===ch.id?"var(--accent)":"var(--border)"}`,
                              background:cur?.id===ch.id?"rgba(124,58,237,0.1)":"var(--surface)",
                              minWidth:84,
                              flexShrink:0
                            }}>
                            <ChannelLogo channel={ch} size={24} />
                            <span style={{fontSize:10,fontWeight:800,overflow:"hidden",display:"-webkit-box",WebkitLineClamp:1,WebkitBoxOrient:"vertical",color:"#fff"}}>{ch.name}</span>
                          </button>
                        );
                      })}
                    </div>
                  </div>
                )}

                {/* Country Groups */}
                {Object.entries(groupedChannels).map(([country, chs]) => (
                  <div key={country} style={{marginBottom:24}}>
                    <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:10,paddingLeft:2}}>
                      <span style={{fontSize:16}}>{FLAGS[country] || "🌐"}</span>
                      <span style={{fontWeight:900,fontSize:11,color:"var(--muted)",textTransform:"uppercase",letterSpacing:1}}>{country}</span>
                      <span style={{fontSize:9,color:"var(--border)",fontWeight:800,background:"rgba(255,255,255,0.03)",padding:"2px 6px",borderRadius:10}}>{chs.length}</span>
                    </div>
                    <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill, minmax(88px, 1fr))",gap:8}}>
                      {chs.map(ch => (
                        <button key={ch.id} onClick={() => playChannel(ch)}
                          style={{
                            display:"flex",
                            flexDirection:"column",
                            alignItems:"center",
                            justifyContent:"center",
                            gap:6,
                            padding:"12px 6px",
                            borderRadius:14,
                            border:`1.5px solid ${cur?.id===ch.id?(ch.isWorldCup?"var(--gold)":"var(--accent)"):"var(--border)"}`,
                            background:cur?.id===ch.id?(ch.isWorldCup?"rgba(245,158,11,0.08)":"rgba(124,58,237,0.12)"):"var(--surface)",
                            cursor:"pointer",
                            boxShadow:cur?.id===ch.id?(ch.isWorldCup?"0 0 10px rgba(245,158,11,0.15)":"0 0 10px rgba(124,58,237,0.15)"):"none"
                          }}>
                          <div style={{height:28,display:"flex",alignItems:"center",justifyContent:"center"}}>
                            <ChannelLogo channel={ch} size={28} />
                          </div>
                          <span style={{fontSize:10,fontWeight:800,lineHeight:1.3,overflow:"hidden",display:"-webkit-box",WebkitLineClamp:2,WebkitBoxOrient:"vertical",color:"#fff"}}>{ch.name}</span>
                          {ch.quality && <span style={{fontSize:8,color:"var(--muted)",fontWeight:800}}>{ch.quality}</span>}
                          {ch.isWorldCup && <span style={{fontSize:8,color:"var(--gold)",fontWeight:900}}>🏆 WC</span>}
                        </button>
                      ))}
                    </div>
                  </div>
                ))}

                {filteredChannels.length === 0 && (
                  <div style={{textAlign:"center",padding:"60px 20px",color:"var(--muted)"}}>
                    <span style={{fontSize:32}}>📺</span>
                    <div style={{fontWeight:800,marginTop:8,color:"#fff"}}>No Channels Found</div>
                    <div style={{fontSize:11,marginTop:4}}>Try another sub-category or search filter.</div>
                  </div>
                )}
              </div>
            )}

            {/* ────────────── TAB: FANCODE DYNAMIC STREAMS ────────────── */}
            {tab === "fancode" && (
              <div className="fade-in">
                <div className="glass-panel glow-green" style={{padding:14,borderRadius:16,marginBottom:18,borderLeft:"3px solid var(--neon-green)"}}>
                  <div style={{fontWeight:900,fontSize:12,color:"var(--neon-green)",letterSpacing:0.5,textTransform:"uppercase",marginBottom:4}}>⚡ FanCode Linear HLS Feeds</div>
                  <div style={{fontSize:10,color:"var(--muted)",lineHeight:1.4}}>Google DAI dynamic streams aggregated from the Live Sports Scraper. Fully working HLS feeds playing advertiser-supported live streams.</div>
                </div>

                {fancodeLoading ? (
                  <div style={{display:"grid",gridTemplateColumns:"1fr",gap:12}}>
                    {[1, 2, 3].map(i => <div key={i} className="skeleton" style={{height:110,borderRadius:16}}/>)}
                  </div>
                ) : fancodeMatches.length === 0 ? (
                  <div style={{textAlign:"center",padding:"40px 20px",color:"var(--muted)",background:"var(--surface)",borderRadius:16,border:"1px dashed var(--border)"}}>
                    <span style={{fontSize:32}}>🏏</span>
                    <div style={{fontWeight:800,marginTop:8,color:"#fff"}}>No Live Match Streams</div>
                    <div style={{fontSize:11,marginTop:4}}>Check back later for active tournament streaming schedules.</div>
                  </div>
                ) : (
                  <div style={{display:"grid",gridTemplateColumns:"1fr",gap:12}}>
                    {fancodeMatches.map(m => (
                      <div key={m.match_id} className="fancode-card" onClick={() => playFancodeMatch(m)}>
                        <span className="fancode-card-badge">{m.event_category}</span>
                        <div style={{display:"flex",alignItems:"center",padding:"14px",gap:12}}>
                          {/* Banner or Flags */}
                          <div style={{position:"relative",width:64,height:48,borderRadius:8,background:"#080816",display:"flex",alignItems:"center",justifyContent:"center",overflow:"hidden",flexShrink:0}}>
                            {m.banner ? (
                              <img src={m.banner} alt={m.event_name} style={{width:"100%",height:"100%",objectFit:"cover"}}/>
                            ) : (
                              <div style={{display:"flex",gap:4}}>
                                <img src={m.team_1_flag} style={{width:20,height:20,objectFit:"contain"}}/>
                                <img src={m.team_2_flag} style={{width:20,height:20,objectFit:"contain"}}/>
                              </div>
                            )}
                          </div>
                          
                          {/* Details */}
                          <div style={{flex:1,minWidth:0}}>
                            <div style={{fontSize:9,fontWeight:900,color:"var(--neon-green)",letterSpacing:0.5}}>{m.event_name}</div>
                            <h4 style={{fontSize:13,fontWeight:900,color:"#fff",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",margin:"2px 0 4px"}}>{m.match_name}</h4>
                            <div style={{fontSize:9,color:"var(--muted)"}}>Scraped: {m.last_updated}</div>
                          </div>

                          {/* Action Button */}
                          <button style={{background:"var(--neon-green)",border:"none",color:"#fff",fontWeight:800,fontSize:10,padding:"6px 12px",borderRadius:8,flexShrink:0}}>
                            WATCH LIVE
                          </button>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}

            {/* ────────────── TAB: LIVE SCORES & FIXTURES ────────────── */}
            {tab === "scores" && (
              <div className="fade-in">
                {/* Timer Info */}
                <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",background:"rgba(16,185,129,0.06)",border:"1px solid var(--border)",borderRadius:12,padding:"8px 12px",fontSize:10,marginBottom:14}}>
                  <div style={{display:"flex",alignItems:"center",gap:6}}>
                    <div style={{width:6,height:6,borderRadius:"50%",background:"var(--neon-green)",boxShadow:"0 0 8px var(--neon-green)",animation:"glow-pulse-g 1.5s infinite"}}/>
                    <span style={{color:"var(--text)",fontWeight:700}}>Live Match Feed ({footballLeague})</span>
                  </div>
                  <div style={{color:"var(--muted)"}}>
                    Refreshes in <span style={{color:"var(--neon-green)",fontWeight:800}}>{footballRefreshTimer}s</span>
                  </div>
                </div>

                {/* Score Filters */}
                <div style={{display:"flex",gap:6,marginBottom:14}}>
                  <button className={`subtab-chip${scoresFilter==="all"?" active":""}`} onClick={() => setScoresFilter("all")}>All</button>
                  <button className={`subtab-chip${scoresFilter==="live"?" active":""}`} onClick={() => setScoresFilter("live")}>● Live</button>
                  <button className={`subtab-chip${scoresFilter==="upcoming"?" active":""}`} onClick={() => setScoresFilter("upcoming")}>Upcoming</button>
                  <button className={`subtab-chip${scoresFilter==="finished"?" active":""}`} onClick={() => setScoresFilter("finished")}>Finished</button>
                </div>

                {footballLoading ? (
                  <div style={{display:"flex",flexDirection:"column",gap:8}}>
                    {[1,2,3,4].map(i => <div key={i} className="skeleton" style={{height:74,borderRadius:12}}/>)}
                  </div>
                ) : filteredFootballMatches.length === 0 ? (
                  <div style={{textAlign:"center",padding:"40px 20px",color:"var(--muted)",background:"var(--surface)",borderRadius:16,border:"1px dashed var(--border)"}}>
                    <span style={{fontSize:32}}>📊</span>
                    <div style={{fontWeight:800,marginTop:8,color:"#fff"}}>No Matches Today</div>
                    <div style={{fontSize:11,marginTop:4}}>No matches match this status filter.</div>
                  </div>
                ) : (
                  <div style={{display:"flex",flexDirection:"column",gap:10}}>
                    {filteredFootballMatches.map(m => (
                      <div key={m.id} className="sports-ticker-card" style={{borderColor: m.status === "LIVE" ? "var(--neon-green)" : "var(--border)"}}>
                        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",fontSize:8,fontWeight:900,color:"var(--muted)",marginBottom:6}}>
                          <span>{m.competition.name}</span>
                          {m.status === "LIVE" && <span style={{color:"var(--neon-green)",animation:"glow-pulse-g 1.5s infinite"}}>● LIVE {m.minute || ""}</span>}
                          {m.status === "FINISHED" && <span style={{color:"var(--muted)"}}>FT</span>}
                          {m.status === "UPCOMING" && <span style={{color:"var(--gold)"}}>{new Date(m.utcDate).toLocaleTimeString([], {hour:"2-digit",minute:"2-digit"})}</span>}
                        </div>

                        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
                          {/* Teams */}
                          <div style={{flex:1,display:"flex",flexDirection:"column",gap:6}}>
                            <div style={{display:"flex",alignItems:"center",gap:8}}>
                              {m.homeTeam.crest && <img src={m.homeTeam.crest} style={{width:16,height:16,objectFit:"contain"}}/>}
                              <span style={{fontSize:12,fontWeight:800,color:"#fff"}}>{m.homeTeam.name}</span>
                            </div>
                            <div style={{display:"flex",alignItems:"center",gap:8}}>
                              {m.awayTeam.crest && <img src={m.awayTeam.crest} style={{width:16,height:16,objectFit:"contain"}}/>}
                              <span style={{fontSize:12,fontWeight:800,color:"#fff"}}>{m.awayTeam.name}</span>
                            </div>
                          </div>

                          {/* Scores */}
                          <div style={{textAlign:"right",paddingLeft:16,display:"flex",flexDirection:"column",gap:6,fontWeight:900,fontSize:13,color:"var(--neon-green)"}}>
                            <div>{m.score.home !== null ? m.score.home : "-"}</div>
                            <div>{m.score.away !== null ? m.score.away : "-"}</div>
                          </div>
                        </div>

                        {/* Broadcast Suggestion Link */}
                        {m.status === "LIVE" && (
                          <div style={{borderTop:"1px solid var(--border)",marginTop:8,paddingTop:6,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                            <span style={{fontSize:9,color:"var(--muted)"}}>Broadcasting on sports channels</span>
                            <button onClick={() => setTab("channels")}
                              style={{background:"none",border:"none",color:"var(--accent)",fontSize:9,fontWeight:800,padding:0}}>
                              📺 GO TO CHANNELS →
                            </button>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}

            {/* ────────────── TAB: LEAGUE STANDINGS ────────────── */}
            {tab === "standings" && (
              <div className="fade-in">
                {standingsLoading ? (
                  <div className="skeleton" style={{height:300,borderRadius:16}}/>
                ) : standings.length === 0 ? (
                  <div style={{textAlign:"center",padding:"40px 20px",color:"var(--muted)"}}>Failed to load standings.</div>
                ) : (
                  <div className="glass-panel" style={{borderRadius:16,overflow:"hidden",border:"1.5px solid var(--border)"}}>
                    <table className="sports-table">
                      <thead>
                        <tr>
                          <th style={{width:30,textAlign:"center"}}>#</th>
                          <th>Team</th>
                          <th style={{textAlign:"center"}}>P</th>
                          <th style={{textAlign:"center"}}>GD</th>
                          <th style={{textAlign:"center",fontWeight:800,color:"#fff"}}>PTS</th>
                        </tr>
                      </thead>
                      <tbody>
                        {standings.map(t => (
                          <tr key={t.position} style={{background: t.position % 2 === 0 ? "rgba(255,255,255,0.01)" : "transparent"}}>
                            <td style={{textAlign:"center",fontWeight:800,color:t.position <= 4 ? "var(--neon-green)" : "var(--muted)"}}>{t.position}</td>
                            <td>
                              <div style={{display:"flex",alignItems:"center",gap:6,fontWeight:750,color:"#fff"}}>
                                {t.team.crest && <img src={t.team.crest} style={{width:14,height:14,objectFit:"contain"}}/>}
                                <span style={{overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:110}}>{t.team.name}</span>
                              </div>
                            </td>
                            <td style={{textAlign:"center",color:"var(--muted)"}}>{t.playedGames}</td>
                            <td style={{textAlign:"center",color:t.goalDifference >= 0 ? "var(--neon-green)" : "#ef4444"}}>{t.goalDifference}</td>
                            <td style={{textAlign:"center",fontWeight:900,color:"var(--neon-green)"}}>{t.points}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            )}

            {/* ────────────── TAB: LEAGUE TOP SCORERS ────────────── */}
            {tab === "scorers" && (
              <div className="fade-in">
                {scorersLoading ? (
                  <div className="skeleton" style={{height:240,borderRadius:16}}/>
                ) : scorers.length === 0 ? (
                  <div style={{textAlign:"center",padding:"40px 20px",color:"var(--muted)"}}>Failed to load scorers.</div>
                ) : (
                  <div className="glass-panel" style={{borderRadius:16,overflow:"hidden",border:"1.5px solid var(--border)"}}>
                    <table className="sports-table">
                      <thead>
                        <tr>
                          <th>Player</th>
                          <th>Team</th>
                          <th style={{textAlign:"center",fontWeight:800,color:"#fff"}}>Goals</th>
                        </tr>
                      </thead>
                      <tbody>
                        {scorers.map((s, idx) => (
                          <tr key={idx} style={{background: idx % 2 === 0 ? "rgba(255,255,255,0.01)" : "transparent"}}>
                            <td>
                              <div style={{fontWeight:800,color:"#fff"}}>{s.name}</div>
                            </td>
                            <td>
                              <div style={{display:"flex",alignItems:"center",gap:6,color:"var(--muted)",fontSize:10}}>
                                {s.team.crest && <img src={s.team.crest} style={{width:12,height:12,objectFit:"contain"}}/>}
                                <span style={{overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:100}}>{s.team.name}</span>
                              </div>
                            </td>
                            <td style={{textAlign:"center",fontWeight:950,color:"var(--neon-green)",fontSize:12}}>{s.goals}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            )}

            {/* ────────────── TAB: WORLD CUP MATCH CENTER ────────────── */}
            {tab === "worldcup" && (
              <div className="fade-in">
                {/* Watch Live WC Section */}
                <div className="glass-panel glow-gold" style={{marginBottom:18,padding:14,borderRadius:16,background:"linear-gradient(135deg,rgba(180,83,9,.15),rgba(12,12,32,0.6))"}}>
                  <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
                    <span style={{fontSize:24}}>🏆</span>
                    <div>
                      <h3 style={{fontWeight:900,fontSize:13,color:"var(--gold)"}}>WATCH WORLD CUP 2026 LIVE</h3>
                      <p style={{fontSize:9,color:"var(--muted)"}}>Select a legal broadcaster channel to start streaming</p>
                    </div>
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill, minmax(90px, 1fr))",gap:6}}>
                    {FEATURED.filter(c => c.isWorldCup).map(ch => (
                      <button key={ch.id} onClick={() => playChannel(ch)}
                        style={{
                          display:"flex",
                          flexDirection:"column",
                          alignItems:"center",
                          justifyContent:"center",
                          gap:4,
                          padding:"8px 4px",
                          borderRadius:10,
                          border:"1px solid var(--gold)",
                          background:"rgba(245,158,11,0.04)",
                          cursor:"pointer"
                        }}>
                        <ChannelLogo channel={ch} size={24} />
                        <span style={{fontSize:9,fontWeight:800,color:"var(--gold)",overflow:"hidden",display:"-webkit-box",WebkitLineClamp:1,WebkitBoxOrient:"vertical"}}>{ch.name}</span>
                      </button>
                    ))}
                  </div>
                </div>

                <div style={{display:"flex",flexDirection:"column",gap:16}}>
                  {/* Info Header */}
                  {wcData && (
                    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",background:"rgba(124,58,237,0.06)",border:"1px solid var(--border)",borderRadius:12,padding:"8px 12px",fontSize:10}}>
                      <div style={{display:"flex",alignItems:"center",gap:6}}>
                        <div style={{width:6,height:6,borderRadius:"50%",background:"var(--gold)",boxShadow:"0 0 8px var(--gold)",animation:"glow-pulse-go 1.5s infinite"}}/>
                        <span style={{color:"var(--muted)"}}>AI Grounding Feed: <span style={{color:"#a78bfa",fontWeight:700}}>{wcData.sourceAgent}</span></span>
                      </div>
                      <span style={{color:"var(--gold)",fontWeight:700}}>{refreshTimer}s</span>
                    </div>
                  )}

                  {/* Filter Search */}
                  {wcData && (
                    <div style={{display:"flex",alignItems:"center",gap:8,background:"var(--surface)",border:"1.5px solid var(--border)",borderRadius:12,padding:"8px 12px"}}>
                      <span style={{color:"var(--muted)",fontSize:13}}>🔍</span>
                      <input placeholder="Filter matches by country name…" value={wcSearch}
                        onChange={e => setWcSearch(e.target.value)}
                        style={{flex:1,background:"transparent",border:"none",outline:"none",color:"var(--text)",fontSize:12}}/>
                    </div>
                  )}

                  {/* Match Reports */}
                  <div>
                    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:10}}>
                      <h4 style={{fontSize:11,fontWeight:900,color:"var(--text)",textTransform:"uppercase",letterSpacing:0.5}}>Match Reports</h4>
                      <button onClick={() => fetchWorldCupData(true)} disabled={wcLoading}
                        style={{background:"rgba(124,58,237,0.1)",border:"1px solid rgba(124,58,237,0.2)",borderRadius:8,padding:"4px 8px",fontSize:8,fontWeight:800,color:"var(--accent)"}}>
                        {wcLoading ? "Updating..." : "⚡ Force AI Update"}
                      </button>
                    </div>

                    {wcLoading && !wcData && <div className="skeleton" style={{height:150,borderRadius:12}}/>}

                    {wcData && filteredReports.map((r: any) => (
                      <div key={r.id} style={{padding:12,borderRadius:12,background:"var(--surface)",border:"1.5px solid var(--border)",position:"relative",marginBottom:8}}>
                        {r.status === "live" && <span style={{position:"absolute",top:10,right:10,background:"#ef4444",color:"#fff",fontSize:8,fontWeight:900,padding:"2px 6px",borderRadius:4,animation:"glow-pulse-g 1.5s infinite"}}>LIVE</span>}
                        {r.status === "finished" && <span style={{position:"absolute",top:10,right:10,background:"#1e293b",color:"var(--muted)",fontSize:8,fontWeight:900,padding:"2px 6px",borderRadius:4}}>FT</span>}
                        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",margin:"8px 0"}}>
                          <div style={{flex:1,fontWeight:800,fontSize:12}}>{r.homeTeam}</div>
                          <div style={{background:"rgba(255,255,255,0.04)",padding:"4px 10px",borderRadius:8,fontWeight:900,fontSize:13,color:"var(--gold)"}}>{r.homeScore} - {r.awayScore}</div>
                          <div style={{flex:1,fontWeight:800,fontSize:12,textAlign:"right"}}>{r.awayTeam}</div>
                        </div>
                        {r.reportSummary && <div style={{fontSize:9.5,color:"var(--muted)",lineHeight:1.4,marginTop:6}}>{r.reportSummary}</div>}
                      </div>
                    ))}
                  </div>

                  {/* Upcoming Schedule */}
                  <div>
                    <h4 style={{fontSize:11,fontWeight:900,color:"var(--text)",textTransform:"uppercase",letterSpacing:0.5,marginBottom:10}}>Next Matches</h4>
                    {wcData && filteredSchedule.slice(0, 4).map((s: any) => (
                      <div key={s.id} style={{display:"flex",alignItems:"center",padding:10,borderRadius:10,background:"var(--surface)",border:"1px solid var(--border)",fontSize:11,marginBottom:6}}>
                        <div style={{flex:1,fontWeight:800}}>{s.homeTeam} vs {s.awayTeam}</div>
                        <div style={{textAlign:"right",fontSize:9,color:"var(--gold)",fontWeight:750}}>{s.time} ({s.date})</div>
                      </div>
                    ))}
                  </div>

                  {/* AI Sports News */}
                  {wcData && wcData.news && (
                    <div>
                      <h4 style={{fontSize:11,fontWeight:900,color:"var(--text)",textTransform:"uppercase",letterSpacing:0.5,marginBottom:10}}>AI Sports News</h4>
                      {wcData.news.slice(0, 2).map((n: any) => (
                        <div key={n.id} style={{padding:10,borderRadius:12,background:"var(--surface)",border:"1px solid var(--border)",marginBottom:6}}>
                          <h5 style={{fontWeight:850,fontSize:11,color:"#fff",lineHeight:1.3}}>{n.title}</h5>
                          <p style={{fontSize:9.5,color:"var(--muted)",marginTop:4}}>{n.summary}</p>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            )}

            <div style={{height:40}}/>
          </div>

          {/* Navigation Bottom Tab Bar */}
          <nav className="tab-bar" style={{flexShrink:0}}>
            {MAIN_TABS.map(t => (
              <button key={t.id}
                className={`tab-btn${tab===t.id?" active":""}${t.id==="worldcup"?" wc-btn":""}`}
                onClick={() => {setTab(t.id);setShowSearch(false);setSearch("");gridRef.current?.scrollTo(0,0);}}>
                <span className="tab-icon">{t.icon}</span>
                <span style={{fontSize:8,fontWeight:800}}>{t.label}</span>
              </button>
            ))}
          </nav>
        </div>

      </div>

      {/* Auth Modal Box */}
      {authModalOpen && (
        <div style={{
          position: "fixed",
          inset: 0,
          background: "rgba(0,0,0,.85)",
          backdropFilter: "blur(8px)",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          zIndex: 1000,
          padding: 16,
          animation: "fadeIn .2s ease"
        }}>
          <div className="glass-panel glow-purple" style={{
            borderRadius: 24,
            width: "100%",
            maxWidth: 380,
            padding: 24,
            position: "relative",
            display: "flex",
            flexDirection: "column",
            gap: 14
          }}>
            <button onClick={() => { setAuthModalOpen(false); setAuthError(""); }}
              style={{
                position: "absolute",
                top: 16,
                right: 16,
                background: "none",
                border: "none",
                color: "var(--muted)",
                fontSize: 18,
                cursor: "pointer"
              }}>
              ✕
            </button>

            <div style={{ textAlign: "center" }}>
              <div style={{ fontSize: 32, marginBottom: 6 }}>⚽</div>
              <h2 style={{ fontSize: 18, fontWeight: 900, background: "linear-gradient(90deg,#10b981,#7c3aed)", WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>
                {authMode === "login" ? "Sign In to Sohan TV" : "Create Account"}
              </h2>
              <p style={{ fontSize: 10, color: "var(--muted)", marginTop: 4 }}>
                Keep your favorites & watch history synced in the cloud.
              </p>
            </div>

            {authError && (
              <div style={{
                background: "rgba(239,68,68,.1)",
                border: "1px solid rgba(239,68,68,.3)",
                color: "#f87171",
                fontSize: 10,
                padding: 10,
                borderRadius: 8,
                fontWeight: 700
              }}>
                ⚠️ {authError}
              </div>
            )}

            <button onClick={handleGoogleSignIn} disabled={authLoading}
              style={{
                width: "100%",
                padding: "10px 16px",
                background: "#fff",
                border: "none",
                borderRadius: 12,
                color: "#000",
                fontSize: 11,
                fontWeight: 800,
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                gap: 8,
                boxShadow: "0 2px 4px rgba(0,0,0,.15)"
              }}>
              <svg style={{ width: 14, height: 14 }} viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05" />
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
              </svg>
              Continue with Google
            </button>

            <div style={{ display: "flex", alignItems: "center" }}>
              <div style={{ flex: 1, height: 1, background: "var(--border)" }}/>
              <span style={{ fontSize: 8, color: "var(--muted)", padding: "0 10px", fontWeight: 800 }}>OR</span>
              <div style={{ flex: 1, height: 1, background: "var(--border)" }}/>
            </div>

            <form onSubmit={handleAuthSubmit} style={{ display: "flex", flexDirection: "column", gap: 10 }}>
              <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
                <label style={{ fontSize: 9, fontWeight: 800, color: "var(--muted)", textTransform: "uppercase" }}>Gmail Address</label>
                <input type="email" required placeholder="example@gmail.com" value={emailInput}
                  onChange={e => setEmailInput(e.target.value)}
                  style={{
                    background: "#060610",
                    border: "1.5px solid var(--border)",
                    borderRadius: 10,
                    padding: "8px 12px",
                    color: "#fff",
                    fontSize: 12,
                    outline: "none"
                  }}/>
              </div>

              <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
                <label style={{ fontSize: 9, fontWeight: 800, color: "var(--muted)", textTransform: "uppercase" }}>Password</label>
                <input type="password" required placeholder="••••••••" value={passwordInput}
                  onChange={e => setPasswordInput(e.target.value)}
                  style={{
                    background: "#060610",
                    border: "1.5px solid var(--border)",
                    borderRadius: 10,
                    padding: "8px 12px",
                    color: "#fff",
                    fontSize: 12,
                    outline: "none"
                  }}/>
              </div>

              <button type="submit" disabled={authLoading}
                style={{
                  width: "100%",
                  padding: "10px 16px",
                  background: "var(--accent)",
                  border: "none",
                  borderRadius: 12,
                  color: "#fff",
                  fontSize: 11,
                  fontWeight: 800,
                  marginTop: 4,
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "center",
                  gap: 8
                }}>
                {authLoading ? "Processing…" : authMode === "login" ? "Sign In" : "Create Account"}
              </button>
            </form>

            <div style={{ borderTop: "1px solid var(--border)", paddingTop: 10, display: "flex", flexDirection: "column", gap: 8, alignItems: "center" }}>
              <button onClick={() => { setAuthMode(authMode === "login" ? "signup" : "login"); setAuthError(""); }}
                style={{ background: "none", border: "none", color: "var(--accent)", fontSize: 10, fontWeight: 800, cursor: "pointer" }}>
                {authMode === "login" ? "New to Sohan TV? Create an account" : "Already have an account? Sign In"}
              </button>
            </div>
          </div>
        </div>
      )}
    </>
  );
}
